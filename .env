VITE_API_BASE=http://localhost:5001

# ── SMART on FHIR ─────────────────────────────────────────────────────────────
# Client ID registered with the EHR / SMART sandbox
VITE_SMART_CLIENT_ID=fhirplace-dev

# Full URL the auth server redirects back to after login.
# NOTE: the app now derives this dynamically from window.location.origin so
# this value is only needed if you want to override (e.g. in production).
# For dev, Vite may run on 5173 or 5174 depending on port availability.
VITE_SMART_REDIRECT_URI=http://localhost:5173/callback

# Default FHIR server for standalone launch (dev / sandbox)
# Use r4.smarthealthit.org for standalone — the launch.smarthealthit.org URL
# is the EHR simulator and requires a launch token from the portal.
VITE_SMART_ISS=https://r4.smarthealthit.org

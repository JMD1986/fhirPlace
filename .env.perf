# ── Perf audit environment ────────────────────────────────────────────────────
# Used exclusively by `npm run build:perf` / `npm run perf:audit`.
# Overrides VITE_API_BASE from .env with a dummy HTTPS URL so the production
# HTTPS security check passes in headless Chromium without a real server.
# The /launch page makes no API calls on mount, so the URL is never requested.

VITE_API_BASE=https://localhost:5001

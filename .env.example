# Copy this file to .env and fill in the values for your environment.
# Never commit .env – it is listed in .gitignore.

# ── Dev server proxy ──────────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:5001

# ── SMART on FHIR ─────────────────────────────────────────────────────────────
# Client ID registered with the EHR / SMART sandbox
VITE_SMART_CLIENT_ID=fhirplace-dev

# Full URL the auth server redirects back to after login.
# The app derives this dynamically from window.location.origin so this value
# is only needed when you want an explicit override (e.g. production).
VITE_SMART_REDIRECT_URI=http://localhost:5173/callback

# Default FHIR server for standalone launch (dev / sandbox)
VITE_SMART_ISS=https://r4.smarthealthit.org

# ── Web Vitals analytics ───────────────────────────────────────────────────────
# HTTPS endpoint that accepts POST requests with a JSON body.
#
# Expected payload shape:
#   {
#     "name":  "LCP",       // Metric name: CLS | FCP | INP | LCP | TTFB
#     "value": 1234.56,     // Current value (ms for time-based metrics; unitless for CLS)
#     "id":    "v4-...",    // Unique per-page-load identifier for deduplication
#     "delta": 1234.56      // Change since the previous report for this metric
#   }
#
# In development the metrics are logged to the console instead.
# If this variable is unset in a production build, a console.warn is emitted
# but no error is thrown.
VITE_VITALS_ENDPOINT=https://your-analytics-endpoint.example.com/vitals
